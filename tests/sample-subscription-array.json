[
  {
    "remarks": "Config PLACEHOLDER 1",
    "log": {
      "loglevel": "warning"
    },
    "inbounds": [
      {
        "tag": "socks-in",
        "listen": "127.0.0.1",
        "port": 1080,
        "protocol": "socks",
        "settings": {
          "auth": "noauth",
          "udp": true,
          "ip": "127.0.0.1"
        }
      }
    ],
    "outbounds": [
      {
        "tag": "vpn-frankfurt-1",
        "remarks": "Frankfurt PLACEHOLDER",
        "protocol": "vless",
        "settings": {
          "vnext": [
            {
              "address": "vless.example.com",
              "port": 443,
              "users": [
                {
                  "id": "11111111-1111-4111-8111-111111111111",
                  "encryption": "none",
                  "flow": "xtls-rprx-vision"
                }
              ]
            }
          ]
        },
        "streamSettings": {
          "network": "tcp",
          "security": "tls",
          "tlsSettings": {
            "serverName": "vless.example.com",
            "fingerprint": "chrome"
          }
        }
      }
    ]
  }
]
