#!/bin/sh /etc/rc.common
# shellcheck disable=SC2034

START=96
STOP=9
USE_PROCD=1

start_service() {
  procd_open_instance
  procd_set_param command /bin/sh -c 'while true; do wget -q -O /tmp/router-policy/watchdog-health.json http://127.0.0.1:8787/api/v1/health >/dev/null 2>/tmp/router-policy/watchdog-health.err || /etc/init.d/router-policy restart; sleep 60; done'
  procd_set_param respawn 5 5 0
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_close_instance
}
