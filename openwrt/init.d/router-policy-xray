#!/bin/sh /etc/rc.common

# rc.common consumes these variables after sourcing the file.
# shellcheck disable=SC2034
USE_PROCD=1
START=96
STOP=10

PROG="${XRAY_BIN:-/usr/bin/xray}"
CONFIG="${ROUTER_POLICY_XRAY_CONFIG:-/etc/router-policy/xray/active.json}"

start_service() {
	[ -x "$PROG" ] || return 1
	[ -s "$CONFIG" ] || return 1
	procd_open_instance router-policy-xray
	procd_set_param command "$PROG" run -config "$CONFIG"
	procd_set_param file "$CONFIG"
	procd_set_param limits nofile="65535 65535"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn 3600 5 5
	procd_close_instance
}

reload_service() {
	stop
	start
}
