#!/bin/sh /etc/rc.common
# shellcheck disable=SC2034

START=95
STOP=10
USE_PROCD=1

start_service() {
  procd_open_instance
  procd_set_param env ROUTER_POLICY_CONFIG=/etc/router-policy/config/default.json
  procd_set_param command /usr/bin/router-policy run --listen 127.0.0.1:8787
  procd_set_param respawn 3600 5 0
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_close_instance
}

reload_service() {
  /usr/bin/router-policy validate-config
}
